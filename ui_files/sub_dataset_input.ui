   <item row="4" column="1">
    <layout class="QGridLayout" name="gridLayout_2">
     <property name="sizeConstraint">
      <enum>QLayout::SizeConstraint::SetDefaultConstraint</enum>
     </property>
     <item row="0" column="1" alignment="Qt::AlignmentFlag::AlignLeft">
      <widget class="QCheckBox" name="flip_augment_enable">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Flip Augment Flips the latents of the images during training, effectively doubling the amount of images. Not recommended for training asymmetrical features, likely not compatible with Cache Latents&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Flip Augment</string>
       </property>
      </widget>
     </item>
     <item row="0" column="0" alignment="Qt::AlignmentFlag::AlignLeft">
      <widget class="QCheckBox" name="shuffle_captions_enable">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Shuffle Captions will shuffle the captions for each image as it appears. It shuffles according to commas. Not compatible with Cache Text Encoder&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Shuffle Captions</string>
       </property>
      </widget>
     </item>
     <item row="1" column="1" alignment="Qt::AlignmentFlag::AlignLeft">
      <widget class="QCheckBox" name="random_crop_enable">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Random Crop replaces the cropping behavior with a crop that originates from a random location of the image, instead of from the center. Not compatible with Cache Latents&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Random Crop</string>
       </property>
      </widget>
     </item>
     <item row="1" column="0" alignment="Qt::AlignmentFlag::AlignLeft">
      <widget class="QCheckBox" name="color_augment_enable">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Color Augment shifts the color of images randomly during training. Suggested to be left off since it changes what the model is supposed to be learning and can impact color accuracy&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Color Augment</string>
       </property>
      </widget>
     </item>
     <item row="2" column="0" colspan="2" alignment="Qt::AlignmentFlag::AlignLeft">
      <widget class="QCheckBox" name="regularization_images_enable">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Regularization Images denotes that this folder's images are meant to be regularization, not for direct training&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Reg Images</string>
       </property>
      </widget>
     </item>
     <item row="2" column="1" alignment="Qt::AlignmentFlag::AlignLeft">
      <widget class="QCheckBox" name="validation_images_enable">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Validation Images denotes that this folder's images are meant to be validation, not for direct training&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Val Images</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
